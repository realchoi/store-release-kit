{
  "name": "@store-release-kit/cli",
  "version": "0.1.0",
  "description": "CLI for GitOps-style store release metadata management.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "store-release": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@store-release-kit/adapters": "workspace:*",
    "@store-release-kit/core": "workspace:*",
    "@store-release-kit/translators": "workspace:*",
    "commander": "^12.1.0",
    "consola": "^3.3.3",
    "dotenv": "^16.4.7",
    "fs-extra": "^11.2.0",
    "yaml": "^2.6.1"
  }
}
